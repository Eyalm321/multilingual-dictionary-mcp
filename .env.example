# Optional: ConceptNet API base URL (defaults to https://api.conceptnet.io)
# CONCEPTNET_BASE_URL=https://api.conceptnet.io

# Optional: Wiktionary base URL (defaults to https://en.wiktionary.org)
# WIKTIONARY_BASE_URL=https://en.wiktionary.org

# Optional: Datamuse base URL (defaults to https://api.datamuse.com)
# DATAMUSE_BASE_URL=https://api.datamuse.com

# Optional: in-memory response cache configuration
# MDM_DISABLE_CACHE=false           # Set to "true" to disable caching entirely
# MDM_CACHE_TTL_MS=86400000         # Cache TTL in milliseconds (default: 24h)
# MDM_CACHE_MAX_ENTRIES=5000        # Max entries before LRU eviction
