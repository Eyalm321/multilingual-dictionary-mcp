{
  "name": "@eyalm321/multilingual-dictionary-mcp",
  "version": "0.3.2",
  "description": "Offline-first MCP server for multilingual dictionary lookups across 4,755 languages — definitions, synonyms, antonyms, hypernyms, hyponyms, meronyms, translations, etymology, semantic neighbors, rhymes, and more. Bundles ConceptNet 5.7, Wiktextract, Numberbatch embeddings, and the CMU Pronouncing Dictionary.",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "dist/index.js",
  "bin": {
    "multilingual-dictionary-mcp": "dist/index.js"
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "dictionary",
    "multilingual",
    "wordnet",
    "conceptnet",
    "wiktionary",
    "datamuse",
    "synonyms",
    "antonyms",
    "translations",
    "claude",
    "model-context-protocol"
  ],
  "author": "Eyalm321",
  "repository": {
    "type": "git",
    "url": "https://github.com/Eyalm321/multilingual-dictionary-mcp.git"
  },
  "homepage": "https://github.com/Eyalm321/multilingual-dictionary-mcp#readme",
  "bugs": {
    "url": "https://github.com/Eyalm321/multilingual-dictionary-mcp/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
